.pytype/

# --- Jupyter ---
.ipynb_checkpoints/

# --- IDE / editor ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- OS ---
.DS_Store
Thumbs.db

# --- Secrets & local config ---
.env
.env.*
!.env.example
*.pem
*.key
secrets.json

# --- Data ---
# Block real / generated patient data, but allow committed sample data under samples/
data/
patient_records/
uploads/
*.tmp.xlsx
*.tmp.csv
# Note: this is a practice project with synthetic data only.
# Never commit real PHI even if the .gitignore would allow it.

# --- Logs / DBs ---
*.log
logs/
*.sqlite
*.sqlite3
*.db

# --- Node (in case you add a JS frontend later) ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
dist/
.next/
